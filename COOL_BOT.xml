<?xml version="1.0" encoding="UTF-8"?>
<block type="bot" id="deriv_advanced_bot">

  <!-- ================= CONFIGURATION ================= -->
  <block type="variables_set" id="config_risk">
    <field name="NAME">risk_percent</field>
    <value name="VALUE">
      <block type="math_number"><field name="NUM">2</field></block>
    </value>
  </block>

  <block type="variables_set" id="config_martingale">
    <field name="NAME">martingale_multiplier</field>
    <value name="VALUE">
      <block type="math_number"><field name="NUM">1.6</field></block>
    </value>
  </block>

  <block type="variables_set" id="config_max_level">
    <field name="NAME">martingale_max_level</field>
    <value name="VALUE">
      <block type="math_number"><field name="NUM">4</field></block>
    </value>
  </block>

  <block type="variables_set" id="config_profit_target">
    <field name="NAME">daily_profit_target</field>
    <value name="VALUE">
      <block type="math_number"><field name="NUM">10</field></block>
    </value>
  </block>

  <block type="variables_set" id="config_loss_limit">
    <field name="NAME">daily_loss_limit</field>
    <value name="VALUE">
      <block type="math_number"><field name="NUM">8</field></block>
    </value>
  </block>

  <!-- ================= MARKET DATA ================= -->
  <block type="tick_analysis" id="market_data">
    <field name="SYMBOL">R_100</field>
  </block>

  <!-- RSI CALCULATION -->
  <block type="rsi" id="rsi_block">
    <field name="PERIOD">14</field>
  </block>

  <!-- EMA SHORT -->
  <block type="ema" id="ema_short">
    <field name="PERIOD">5</field>
  </block>

  <!-- EMA LONG -->
  <block type="ema" id="ema_long">
    <field name="PERIOD">20</field>
  </block>

  <!-- ================= STRATEGY LOGIC ================= -->
  <block type="logic_compare" id="trend_condition">
    <field name="OP">GT</field>
    <value name="A">
      <block type="variables_get"><field name="VAR">ema_short</field></block>
    </value>
    <value name="B">
      <block type="variables_get"><field name="VAR">ema_long</field></block>
    </value>
  </block>

  <block type="logic_compare" id="rsi_buy_condition">
    <field name="OP">LT</field>
    <value name="A">
      <block type="variables_get"><field name="VAR">rsi</field></block>
    </value>
    <value name="B">
      <block type="math_number"><field name="NUM">30</field></block>
    </value>
  </block>

  <block type="logic_compare" id="rsi_sell_condition">
    <field name="OP">GT</field>
    <value name="A">
      <block type="variables_get"><field name="VAR">rsi</field></block>
    </value>
    <value name="B">
      <block type="math_number"><field name="NUM">70</field></block>
    </value>
  </block>

  <!-- ================= TRADE EXECUTION ================= -->
  <block type="if" id="buy_condition_block">
    <value name="IF0">
      <block type="logic_and">
        <value name="A">
          <block type="variables_get"><field name="VAR">trend_up</field></block>
        </value>
        <value name="B">
          <block type="variables_get"><field name="VAR">rsi_buy_condition</field></block>
        </value>
      </block>
    </value>

    <statement name="DO0">
      <block type="trade_buy">
        <field name="CONTRACT_TYPE">CALL</field>
        <field name="STAKE">auto</field>
        <field name="DURATION">5</field>
      </block>
    </statement>
  </block>

  <block type="if" id="sell_condition_block">
    <value name="IF0">
      <block type="logic_and">
        <value name="A">
          <block type="variables_get"><field name="VAR">trend_down</field></block>
        </value>
        <value name="B">
          <block type="variables_get"><field name="VAR">rsi_sell_condition</field></block>
        </value>
      </block>
    </value>

    <statement name="DO0">
      <block type="trade_buy">
        <field name="CONTRACT_TYPE">PUT</field>
        <field name="STAKE">auto</field>
        <field name="DURATION">5</field>
      </block>
    </statement>
  </block>

  <!-- ================= MARTINGALE SYSTEM ================= -->
  <block type="logic_ifelse" id="martingale_logic">

    <value name="IF0">
      <block type="variables_get"><field name="VAR">last_trade_loss</field></block>
    </value>

    <statement name="DO0">
      <block type="variables_set">
        <field name="NAME">current_level</field>
        <value name="VALUE">
          <block type="math_arithmetic">
            <field name="OP">MULTIPLY</field>
            <value name="A">
              <block type="variables_get"><field name="VAR">current_level</field></block>
            </value>
            <value name="B">
              <block type="variables_get"><field name="VAR">martingale_multiplier</field></block>
            </value>
          </block>
        </value>
      </block>
    </statement>

    <statement name="ELSE">
      <block type="variables_set">
        <field name="NAME">current_level</field>
        <value name="VALUE">
          <block type="math_number"><field name="NUM">1</field></block>
        </value>
      </block>
    </statement>

  </block>

  <!-- ================= RISK MANAGEMENT ================= -->
  <block type="logic_if" id="risk_stop_loss">
    <value name="IF0">
      <block type="logic_or">
        <value name="A">
          <block type="variables_get"><field name="VAR">daily_loss_limit_reached</field></block>
        </value>
        <value name="B">
          <block type="variables_get"><field name="VAR">daily_profit_target_reached</field></block>
        </value>
      </block>
    </value>

    <statement name="DO0">
      <block type="trade_stop_all"></block>
    </statement>
  </block>

  <!-- ================= LOOP ================= -->
  <block type="controls_whileTrue" id="main_loop">
    <statement name="DO">
      <block type="tick_update"></block>
    </statement>
  </block>

</block>
